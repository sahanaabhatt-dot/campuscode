<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark" android:orientation="vertical">

    <!-- Toolbar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="@color/bg_card" android:orientation="horizontal"
        android:gravity="center_vertical" android:paddingStart="8dp" android:paddingEnd="16dp">
        <Button android:id="@+id/btnBack" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="←" android:backgroundTint="@android:color/transparent" android:textColor="@color/text_white"/>
        <TextView android:id="@+id/tvProblemTitle" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textColor="@color/text_white" android:textSize="15sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvDifficulty" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/easy_green" android:textSize="12sp" android:textStyle="bold"/>
    </LinearLayout>

    <!-- Language + Run/Submit -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
        android:background="@color/bg_card" android:orientation="horizontal"
        android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
        <Spinner android:id="@+id/spinnerLang" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"/>
        <Button android:id="@+id/btnRun" android:layout_width="wrap_content" android:layout_height="36dp"
            android:text="▶ Run" android:textSize="12sp" android:backgroundTint="#2A1A3D"
            android:textColor="@color/easy_green" android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btnSubmit" android:layout_width="wrap_content" android:layout_height="36dp"
            android:text="Submit" android:textSize="12sp" android:backgroundTint="@color/easy_green"
            android:textColor="#0F0A1A" android:textStyle="bold"/>
    </LinearLayout>

    <!-- Code Editor -->
    <EditText android:id="@+id/etCode" android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="2" android:background="#0D0D1A" android:textColor="@color/text_white"
        android:fontFamily="monospace" android:textSize="13sp" android:padding="12dp"
        android:gravity="top|start" android:inputType="textMultiLine" android:scrollbars="vertical"/>

    <!-- Input -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Input (stdin):" android:textColor="@color/text_gray" android:textSize="12sp"
        android:background="@color/bg_card" android:padding="8dp" android:paddingStart="16dp"/>
    <EditText android:id="@+id/etInput" android:layout_width="match_parent" android:layout_height="60dp"
        android:background="@color/bg_input" android:textColor="@color/text_white"
        android:fontFamily="monospace" android:textSize="13sp" android:padding="12dp"
        android:hint="Enter input here..." android:textColorHint="@color/text_gray"
        android:gravity="top|start" android:inputType="textMultiLine"/>

    <!-- Output -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Output:" android:textColor="@color/text_gray" android:textSize="12sp"
        android:background="@color/bg_card" android:padding="8dp" android:paddingStart="16dp"/>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:background="#0D0D1A">
        <TextView android:id="@+id/tvOutput" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_white" android:fontFamily="monospace" android:textSize="13sp"
            android:padding="12dp" android:text="Run your code to see output..."/>
    </ScrollView>
</LinearLayout>
