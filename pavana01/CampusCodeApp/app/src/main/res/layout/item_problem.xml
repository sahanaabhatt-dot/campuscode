<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:background="@drawable/card_bg" android:orientation="horizontal"
    android:padding="16dp" android:layout_marginBottom="8dp" android:gravity="center_vertical">

    <TextView android:id="@+id/tvProblemNum" android:layout_width="36dp" android:layout_height="36dp"
        android:background="@drawable/input_bg" android:gravity="center"
        android:textColor="@color/text_gray" android:textSize="14sp"/>

    <TextView android:id="@+id/tvProblemTitle" android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:textColor="@color/text_white" android:textSize="15sp"
        android:layout_marginStart="12dp"/>

    <TextView android:id="@+id/tvDifficulty" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="12sp" android:textStyle="bold"/>
</LinearLayout>
